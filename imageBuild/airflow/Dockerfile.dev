# =============================================================================
# Domino Airflow 开发镜像（热重载）
# 基础镜像: apache/airflow:2.9.3-python3.11
# 用途: 本地开发 — airflow-scheduler/worker，挂载 domino-py 源码目录
# =============================================================================

FROM apache/airflow:2.9.3-python3.11

LABEL maintainer="Domino Team"
LABEL description="Domino Airflow dev image — installs domino-py from local source in editable mode"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_COLOR=1

USER root
RUN apt-get update --quiet \
    && apt-get install --yes --quiet --no-install-recommends \
        git \
        curl \
        nano \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 将 pyproject.toml 和源码复制进镜像
# 在 compose 开发模式下，该目录会被 volume 覆盖实现热重载
USER airflow
RUN mkdir -p /opt/airflow/domino/domino_py

COPY --chown=airflow:0 pyproject.toml /opt/airflow/domino/domino_py/
COPY --chown=airflow:0 src/domino /opt/airflow/domino/domino_py/src/domino

WORKDIR /opt/airflow/domino/domino_py

USER root
# 确保 airflow 用户可写（editable install 需要）
RUN chmod -R 775 .

USER airflow
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e ".[airflow]"

WORKDIR /opt/airflow
