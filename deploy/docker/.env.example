# =============================================================================
# Domino Docker Compose 环境变量示例
# 复制此文件为 .env 并按实际情况填写
# =============================================================================

# ── 数据库 ────────────────────────────────────────────────────────────────────
DOMINO_DB_USER=postgres
DOMINO_DB_PASSWORD=postgres_secret_change_me
DOMINO_DB_NAME=domino

AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_secret_change_me
AIRFLOW_DB_NAME=airflow

# ── Airflow 核心 ──────────────────────────────────────────────────────────────
# Fernet key（必须是 32 字节 base64 编码）
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

# Airflow 初始管理员账号
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow_admin_change_me

# Airflow UID（Linux 用户）：sudo whoami => 填入 UID
AIRFLOW_UID=50000

# ── Domino REST 服务 ───────────────────────────────────────────────────────────
# JWT / 加密密钥
GIT_TOKEN_SECRET_KEY=j1DsRJ-ehxU_3PbXW0c_-U4nTOx3knRB4zzWguMVaio=

# 初始管理员账户（首次部署时自动创建）
# 注意：部署后建议修改为强密码，或在生产环境中禁用自动创建
ADMIN_USER_EMAIL=admin@email.com
ADMIN_USER_PASSWORD=admin
CREATE_DEFAULT_USER=true

# 工作流存储模式: local（本地文件系统） | git（推送到远端仓库）
DOMINO_WORKFLOW_STORAGE_MODE=local

# 当 DOMINO_WORKFLOW_STORAGE_MODE=git 时填写以下内容
# DOMINO_WORKFLOWS_GIT_REPO_URL=https://github.com/your-org/your-workflows-repo
# DOMINO_WORKFLOWS_GIT_REPO_BRANCH=main
# DOMINO_WORKFLOWS_GIT_TOKEN=ghp_xxxxxxxxxxxx

# 默认 Pieces 仓库配置（可选）
# DOMINO_DEFAULT_PIECES_REPOSITORY_VERSION=0.6.0
# DOMINO_DEFAULT_PIECES_REPOSITORY_TOKEN=

# ── 前端 ──────────────────────────────────────────────────────────────────────
# REST API 地址（浏览器能访问到的地址）
# 重要：此值会在容器启动时注入前端，必须使用浏览器可访问的地址
# - 本机访问：http://localhost:8000
# - 局域网/远程访问：http://<服务器IP>:8000（如 http://172.16.0.30:8000）
API_URL=http://localhost:8000

# ── 部署模式 ──────────────────────────────────────────────────────────────────
# Domino 部署模式：docker-compose（固定值，勿修改）
DOMINO_DEPLOY_MODE=docker-compose
